# =============================================================================
# OMR Salespage — Environment Variables
# Copy to `.env.local` and fill in. Defaults make the app runnable in mock mode.
# =============================================================================

# --- Analyzer mode -----------------------------------------------------------
# `mock` returns canned analysis data (no API key needed). `live` calls Anthropic.
ANALYZER_MODE=mock

# --- Anthropic (only for ANALYZER_MODE=live) ---------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase (leads). If empty, leads land in ./.data/leads.ndjson ----------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend). If empty, lead notifications are console-logged ---------
RESEND_API_KEY=
LEAD_NOTIFICATION_TO=sales@voggs.net
LEAD_NOTIFICATION_FROM=no-reply@voggs.net

# --- Storage (Vercel Blob). If empty, uploads land in ./.data/uploads --------
BLOB_READ_WRITE_TOKEN=

# --- Rate limit (Upstash Redis). If empty, in-memory fallback (dev only) -----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare Turnstile (anti-spam, stub) ----------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Cleanup cron (auth header for /api/cleanup) -----------------------------
CLEANUP_CRON_SECRET=
